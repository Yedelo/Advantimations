{
  "required": true,
  "package": "at.yedel.advantimations.mixin",
  "compatibilityLevel": "${mixinJava}",
  "client": [
    "AvatarRendererMixin",
    "EntityRenderStateMixin",
    "GuiMixin",
    "HumanoidMobRendererMixin",
    "HumanoidModelMixin",
    "IsUsingItemMixin",
    "ItemInHandRendererMixin",
    /*? >= 1.21.9 {*/ "LevelRendererMixin",
    /*?} else {*//*"EntityRenderDispatcherMixin",*//*?}*/
    "LivingEntityRendererMixin",
    "MinecraftMixin",
    "PlayerItemInHandLayerMixin",
    /*? if spear {*/ "SpearAnimationsMixin", /*?}*/
    "UseCycleMixin"
  ],
  // hello comment
  /* multiline comment */
  "injectors": {
    "defaultRequire": 1
  }
}